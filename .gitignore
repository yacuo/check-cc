# CheckCC 的 Git 忽略规则，用于排除依赖、构建产物、环境变量、本地调试文件和系统临时文件。
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
/logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# local overrides
*.local
